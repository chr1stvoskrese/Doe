//
//  ColumnView.swift
//  Doe
//
//  Колонка: шапка с названием/режимом/меню, список карточек с drag-and-drop
//  (переупорядочивание и перенос между колонками), поле добавления карточки.
//  Сама колонка перетаскивается за шапку (reorder колонок).
//

import SwiftUI

struct ColumnView: View {
    @ObservedObject var vm: BoardViewModel
    let column: Column
    @Binding var openTaskId: Int64?

    @State private var newCardText = ""
    @State private var isDropTargetEnd = false
    @State private var renaming = false
    @State private var draftTitle = ""
    @FocusState private var addFocused: Bool

    private var tasks: [Task] { vm.tasksByColumn[column.id] ?? [] }
    private var width: CGFloat { CGFloat(column.width ?? Double(Theme.columnWidth)) }

    var body: some View {
        VStack(spacing: 0) {
            header
            Divider().overlay(Theme.modeTint(column.mode).opacity(0.4))
            cardList
            addRow
        }
        .frame(width: width)
        .background(Theme.columnBackground)
        .clipShape(RoundedRectangle(cornerRadius: Theme.columnCorner))
        .overlay(
            RoundedRectangle(cornerRadius: Theme.columnCorner)
                .strokeBorder(Theme.hairline.opacity(0.5), lineWidth: 0.5)
        )
        // Колонка принимает другую колонку (reorder). Перетаскивается за шапку.
        .dropDestination(for: ColumnRef.self) { items, _ in
            guard let dragged = items.first, dragged.id != column.id else { return false }
            reorderColumns(movingId: dragged.id, beforeId: column.id)
            return true
        }
    }

    // MARK: - Шапка

    private var header: some View {
        HStack(spacing: 8) {
            Circle().fill(Theme.modeTint(column.mode)).frame(width: 8, height: 8)
            if renaming {
                TextField("Название", text: $draftTitle, onCommit: commitRename)
                    .textFieldStyle(.roundedBorder)
                    .font(.headline)
            } else {
                Text(column.title)
                    .font(.headline)
                    .lineLimit(1)
                    .onTapGesture { startRename() }
            }
            Spacer(minLength: 4)
            Text("\(tasks.count)")
                .font(.caption).monospacedDigit()
                .foregroundStyle(Theme.textSecondary)
            Menu {
                Button { startRename() } label: { Label("Переименовать", systemImage: "pencil") }
                Menu("Режим") {
                    ForEach(ColumnMode.allCases) { m in
                        Button { vm.setColumnMode(column.id, mode: m) } label: {
                            Label(m.title, systemImage: column.mode == m ? "checkmark" : "")
                        }
                    }
                }
                Divider()
                Button(role: .destructive) { vm.deleteColumn(column.id) } label: {
                    Label("Удалить колонку", systemImage: "trash")
                }
            } label: {
                Image(systemName: "ellipsis").foregroundStyle(Theme.textSecondary).padding(.leading, 2)
            }
        }
        .padding(.horizontal, 12).padding(.vertical, 10)
        .contentShape(Rectangle())
        // Перетаскивание колонки за шапку (reorder колонок).
        .draggable(ColumnRef(id: column.id)) {
            Text(column.title).font(.headline).padding(10)
                .background(Theme.columnBackground)
                .clipShape(RoundedRectangle(cornerRadius: 8))
        }
    }

    // MARK: - Список карточек

    private var cardList: some View {
        ScrollView(.vertical, showsIndicators: false) {
            LazyVStack(spacing: Theme.spacing) {
                ForEach(tasks) { task in
                    CardView(task: task,
                             subtaskCount: vm.subtasks(of: task.id).count,
                             reminderDate: vm.reminderDate(for: task.id))
                        .contentShape(RoundedRectangle(cornerRadius: Theme.cardCorner))
                        .onTapGesture { openTaskId = task.id }
                        .draggable(TaskRef(id: task.id, sourceColumnId: column.id)) {
                            CardView(task: task, subtaskCount: 0)
                                .frame(width: width - 24)
                                .opacity(0.95)
                        }
                        .dropDestination(for: TaskRef.self) { items, _ in
                            guard let ref = items.first else { return false }
                            vm.handleCardDrop(ref, targetColumnId: column.id, beforeId: task.id)
                            return true
                        }
                        .contextMenu {
                            Button { openTaskId = task.id } label: { Label("Открыть", systemImage: "square.and.pencil") }
                            Button(role: .destructive) { vm.deleteTask(task.id) } label: {
                                Label("Удалить", systemImage: "trash")
                            }
                        }
                        .transition(.scale.combined(with: .opacity))
                }

                // Зона приёма в конец колонки.
                Color.clear
                    .frame(height: max(40, tasks.isEmpty ? 80 : 40))
                    .frame(maxWidth: .infinity)
                    .overlay(
                        Group {
                            if tasks.isEmpty {
                                Text("Перетащите сюда").font(.caption)
                                    .foregroundStyle(Theme.textSecondary)
                            }
                        }
                    )
                    .background(isDropTargetEnd ? Theme.accent.opacity(0.08) : Color.clear)
                    .dropDestination(for: TaskRef.self) { items, _ in
                        guard let ref = items.first else { return false }
                        vm.handleCardDrop(ref, targetColumnId: column.id, beforeId: nil)
                        return true
                    } isTargeted: { isDropTargetEnd = $0 }
            }
            .padding(.horizontal, 12)
            .padding(.vertical, 10)
            .animation(.spring(response: 0.32, dampingFraction: 0.82), value: tasks)
        }
    }

    // MARK: - Добавление

    private var addRow: some View {
        HStack(spacing: 8) {
            TextField("Новая карточка…", text: $newCardText, axis: .vertical)
                .textFieldStyle(.plain)
                .focused($addFocused)
                .onSubmit(commitAdd)
            if !newCardText.trimmingCharacters(in: .whitespaces).isEmpty {
                Button(action: commitAdd) {
                    Image(systemName: "arrow.up.circle.fill").font(.title3)
                }
            }
        }
        .padding(.horizontal, 12).padding(.vertical, 10)
        .background(Theme.elevated.opacity(0.5))
    }

    private func commitAdd() {
        vm.addTask(columnId: column.id, title: newCardText)
        newCardText = ""
    }

    private func startRename() { draftTitle = column.title; renaming = true }
    private func commitRename() {
        renaming = false
        let t = draftTitle.trimmingCharacters(in: .whitespacesAndNewlines)
        if !t.isEmpty && t != column.title { vm.renameColumn(column.id, to: t) }
    }

    private func reorderColumns(movingId: Int64, beforeId: Int64) {
        var ids = vm.columns.map(\.id)
        guard let from = ids.firstIndex(of: movingId) else { return }
        ids.remove(at: from)
        guard let to = ids.firstIndex(of: beforeId) else { return }
        ids.insert(movingId, at: to)
        withAnimation(.spring(response: 0.32, dampingFraction: 0.82)) {
            vm.reorderColumns(ids)
        }
    }
}
