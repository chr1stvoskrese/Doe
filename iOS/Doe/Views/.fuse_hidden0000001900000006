import SwiftUI

struct CardView: View {
    let task: Task
    let subtaskCount: Int
    var reminderDate: Date? = nil

    var body: some View {
        VStack(alignment: .leading, spacing: 8) {
            Text(titleAttributed)
                .font(.body)
                .foregroundStyle(Theme.textPrimary)
                .multilineTextAlignment(.leading)
                .lineLimit(4)

            if hasMeta {
                HStack(spacing: 12) {
                    if hasDescription {
                        Image(systemName: "text.alignleft")
                            .foregroundStyle(Theme.textSecondary)
                    }
                    if subtaskCount > 0 {
                        Label("\(subtaskCount)", systemImage: "rectangle.stack")
                            .labelStyle(.titleAndIcon)
                            .foregroundStyle(Theme.textSecondary)
                    }
                    if let due = reminderDate {
                        Label(dueText(due), systemImage: "bell")
                            .foregroundStyle(isOverdue(due) ? .red : Theme.textSecondary)
                    }
                    Spacer(minLength: 0)
                    if task.completedAt != nil {
                        Image(systemName: "checkmark.circle.fill")
                            .foregroundStyle(Theme.modeTint(.completion))
                    }
                }
                .font(.caption)
            }
        }
        .padding(12)
        .frame(maxWidth: .infinity, alignment: .leading)
        .background(Theme.cardBackground)
        .clipShape(RoundedRectangle(cornerRadius: Theme.cardCorner))
        .overlay(
            RoundedRectangle(cornerRadius: Theme.cardCorner)
                .strokeBorder(Theme.hairline.opacity(0.6), lineWidth: 0.5)
        )
        .doeShadow(4)
    }

    private var hasDescription: Bool {
        !(task.description ?? "").trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
    }
    private var hasMeta: Bool { hasDescription || subtaskCount > 0 || reminderDate != nil || task.completedAt != nil }

    private var titleAttributed: AttributedString {
        (try? AttributedString(markdown: task.displayTitle,
                               options: .init(interpretedSyntax: .inlineOnlyPreservingWhitespace)))
            ?? AttributedString(task.displayTitle)
    }

    private func dueText(_ date: Date) -> String {
        let f = DateFormatter()
        f.locale = Locale(identifier: "ru_RU")
        f.dateFormat = Calendar.current.isDateInToday(date) ? "HH:mm" : "d MMM HH:mm"
        return f.string(from: date)
    }

    private func isOverdue(_ date: Date) -> Bool { date < Date() }
}
